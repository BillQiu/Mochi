; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Mochi — Concept Prototype"
config/description="Throwaway prototype for Mochi. Tests the core 30s micro-loop: pull the lever, watch Mochi crush, tap the silhouette to reveal. Validate: do testers spontaneously pull again within 10s of first reveal?"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="canvas_items"

[rendering]

environment/defaults/default_clear_color=Color(0.965, 0.945, 0.906, 1)
