[gd_resource type="Theme" load_steps=10 format=3]

; Mochi 基础 Theme — 把 design tokens 烧进 Godot 默认 Control 样式。
; 任何 Control 节点放上 Main scene 后会自动继承这些样式。
; 多层 plush shadow (contact + ambient) Godot StyleBoxFlat 不支持原生双层，
; 需要在消费端用嵌套 Panel 实现 contact 层；这里默认只挂 ambient 层 (shadow-2)。
;
; 注意：display font (Fredoka) 不在 Theme 默认字段里挂全局，因为它只服务 wordmark
; 和大数字。消费端用 `var f := load("res://assets/fonts/Fredoka-Variable.ttf")`
; 然后 `label.add_theme_font_override("font", f)` 即可。

[sub_resource type="SystemFont" id="SystemFont_body"]
font_names = PackedStringArray("PingFang SC", "Hiragino Sans GB", "Noto Sans SC", "Microsoft YaHei", "system-ui")

